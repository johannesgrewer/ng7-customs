{
  "rewrites": [
    { "source": "/admin",           "destination": "https://ng7-contact.contact-1f9.workers.dev/admin" },
    { "source": "/admin/:path*",    "destination": "https://ng7-contact.contact-1f9.workers.dev/admin/:path*" },
    { "source": "/api/contact",     "destination": "https://ng7-contact.contact-1f9.workers.dev/api/contact" },
    { "source": "/api/werke",       "destination": "https://ng7-contact.contact-1f9.workers.dev/api/werke" },
    { "source": "/api/werke/:path*","destination": "https://ng7-contact.contact-1f9.workers.dev/api/werke/:path*" },
    { "source": "/api/upload",      "destination": "https://ng7-contact.contact-1f9.workers.dev/api/upload" },
    { "source": "/api/deploy",      "destination": "https://ng7-contact.contact-1f9.workers.dev/api/deploy" },
    { "source": "/api/settings",    "destination": "https://ng7-contact.contact-1f9.workers.dev/api/settings" },
    { "source": "/api/settings/:path*", "destination": "https://ng7-contact.contact-1f9.workers.dev/api/settings/:path*" },
    { "source": "/images/:path*",   "destination": "https://ng7-contact.contact-1f9.workers.dev/images/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
      ]
    }
  ]
}

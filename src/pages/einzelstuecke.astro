---
import Layout from '../layouts/Layout.astro';
import ShopGrid from '../components/ShopGrid.astro';

const produkte = [
  { name: 'Messerkordel I', preis: '3.000,00€', bild: '/images/produkt-01.jpg' },
  { name: 'Messerkordel II', preis: '3.000,00€', bild: '/images/produkt-02.jpg' },
  { name: 'Messerkordel III', preis: '3.000,00€', bild: '/images/produkt-03.jpg' },
  { name: 'Messerkordel IV', preis: '3.000,00€', bild: '/images/produkt-04.jpg' },
  { name: 'Phone Stand', preis: '3.000,00€', bild: '/images/produkt-phone-stand.png' },
];
---

<Layout title="Nach Maß Page" description="Maßanfertigungen von NG7 Customs — Einzelstücke nach deinen Wünschen.">
  <ShopGrid
    title="Nach Maß Page"
    breadcrumb="Nach Maß Page"
    produkte={produkte}
    activeCategory="Nach Maß Page"
  />
</Layout>

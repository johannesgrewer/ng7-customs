---
import Layout from '../layouts/Layout.astro';
import ShopGrid from '../components/ShopGrid.astro';

const produkte = [
  { name: 'Messerkordel I', bild: '/images/produkt-01.webp' },
  { name: 'Messerkordel II', bild: '/images/produkt-02.webp' },
  { name: 'Messerkordel III', bild: '/images/produkt-03.webp' },
  { name: 'Messerkordel IV', bild: '/images/produkt-04.webp' },
  { name: 'Phone Stand', bild: '/images/produkt-phone-stand.webp' },
];
---

<Layout title="Einzelstücke" description="Maßanfertigungen von NG7 Customs — Einzelstücke nach deinen Wünschen.">
  <ShopGrid
    title="Einzelstücke"
    breadcrumb="Einzelstücke"
    produkte={produkte}
    activeCategory="Einzelstücke"
    description="Unikate mit Charakter. Jedes Stück ein Original aus Handarbeit."
  />
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt" description="Kontaktiere NG7 Customs — Anfragen für Einzelstücke, Custom-Arbeiten und Entwicklung. Nicolas Meriaux, Trier.">

  <!-- Page Header -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--ng7-accent)] mb-3">Kontakt</p>
      <h1 style="font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 7vw, 5rem); letter-spacing: 0.02em;">Schreib mir</h1>
      <p class="mt-4 text-[var(--ng7-text-dim)] max-w-xl leading-relaxed">
        Erzähl mir von deiner Idee — ob Einzelstück, Custom-Arbeit oder Entwicklungsprojekt. Ich melde mich innerhalb von 24 Stunden.
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="pb-24 px-6">
    <div class="max-w-4xl mx-auto grid grid-cols-1 lg:grid-cols-5 gap-12">

      <!-- Formular -->
      <div class="lg:col-span-3">
        <form class="flex flex-col gap-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-xs uppercase tracking-widest text-[var(--ng7-text-muted)] mb-2">Name *</label>
              <input type="text" name="name" required
                class="w-full bg-[var(--ng7-surface)] border border-[var(--ng7-border)] text-[var(--ng7-text)] px-4 py-3 text-sm focus:border-[var(--ng7-accent)] focus:outline-none transition-colors"
                placeholder="Dein Name" />
            </div>
            <div>
              <label class="block text-xs uppercase tracking-widest text-[var(--ng7-text-muted)] mb-2">E-Mail *</label>
              <input type="email" name="email" required
                class="w-full bg-[var(--ng7-surface)] border border-[var(--ng7-border)] text-[var(--ng7-text)] px-4 py-3 text-sm focus:border-[var(--ng7-accent)] focus:outline-none transition-colors"
                placeholder="deine@email.de" />
            </div>
          </div>

          <div>
            <label class="block text-xs uppercase tracking-widest text-[var(--ng7-text-muted)] mb-2">Kategorie</label>
            <select name="kategorie"
              class="w-full bg-[var(--ng7-surface)] border border-[var(--ng7-border)] text-[var(--ng7-text-dim)] px-4 py-3 text-sm focus:border-[var(--ng7-accent)] focus:outline-none transition-colors appearance-none">
              <option value="">Bitte wählen</option>
              <option value="einzelstueck">Einzelstück</option>
              <option value="entwicklung">Entwicklung / Prototyp</option>
              <option value="custom">Custom / Finish</option>
              <option value="shop">Shop-Artikel</option>
              <option value="sonstiges">Sonstiges</option>
            </select>
          </div>

          <div>
            <label class="block text-xs uppercase tracking-widest text-[var(--ng7-text-muted)] mb-2">Deine Nachricht *</label>
            <textarea name="nachricht" rows="6" required
              class="w-full bg-[var(--ng7-surface)] border border-[var(--ng7-border)] text-[var(--ng7-text)] px-4 py-3 text-sm focus:border-[var(--ng7-accent)] focus:outline-none transition-colors resize-y"
              placeholder="Beschreib dein Projekt, deine Idee oder deinen Wunsch..."></textarea>
          </div>

          <div>
            <label class="block text-xs uppercase tracking-widest text-[var(--ng7-text-muted)] mb-2">Fotos / Referenzen (optional)</label>
            <div class="border border-dashed border-[var(--ng7-border)] bg-[var(--ng7-surface)] p-8 text-center hover:border-[var(--ng7-accent)] transition-colors cursor-pointer">
              <p class="text-sm text-[var(--ng7-text-dim)]">Dateien hierher ziehen oder klicken</p>
              <p class="text-xs text-[var(--ng7-text-muted)] mt-1">JPG, PNG, PDF — max. 10 MB</p>
            </div>
          </div>

          <div>
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" required class="mt-1 accent-[var(--ng7-accent)]" />
              <span class="text-xs text-[var(--ng7-text-dim)] leading-relaxed">
                Ich stimme der Verarbeitung meiner Daten gemäß der <a href="/datenschutz" class="text-[var(--ng7-accent)] underline">Datenschutzerklärung</a> zu. *
              </span>
            </label>
          </div>

          <button type="submit" class="btn-primary self-start">Anfrage senden</button>
        </form>
      </div>

      <!-- Kontakt-Info -->
      <div class="lg:col-span-2">
        <div class="border border-[var(--ng7-border)] bg-[var(--ng7-surface)] p-8 sticky top-28">
          <h3 class="text-sm uppercase tracking-widest mb-6">Direkt erreichen</h3>

          <div class="flex flex-col gap-5">
            <div>
              <p class="text-xs text-[var(--ng7-text-muted)] uppercase tracking-widest mb-1">E-Mail</p>
              <a href="mailto:nicolas.mrx@googlemail.com" class="text-sm text-[var(--ng7-text-dim)] hover:text-[var(--ng7-accent)] transition-colors">
                nicolas.mrx@googlemail.com
              </a>
            </div>

            <div>
              <p class="text-xs text-[var(--ng7-text-muted)] uppercase tracking-widest mb-1">Instagram</p>
              <a href="https://www.instagram.com/ng7_customs/" target="_blank" rel="noopener" class="text-sm text-[var(--ng7-text-dim)] hover:text-[var(--ng7-accent)] transition-colors">
                @ng7_customs
              </a>
            </div>

            <div>
              <p class="text-xs text-[var(--ng7-text-muted)] uppercase tracking-widest mb-1">Standort</p>
              <p class="text-sm text-[var(--ng7-text-dim)]">Trier, Deutschland</p>
            </div>

            <hr class="border-[var(--ng7-border)]" />

            <div>
              <p class="text-xs text-[var(--ng7-text-muted)] uppercase tracking-widest mb-1">Antwortzeit</p>
              <p class="text-sm text-[var(--ng7-text-dim)]">In der Regel innerhalb von 24h</p>
            </div>

            <div>
              <p class="text-xs text-[var(--ng7-text-muted)] uppercase tracking-widest mb-1">Hinweis</p>
              <p class="text-xs text-[var(--ng7-text-dim)] leading-relaxed">
                Alle Arbeiten sind Einzelanfertigungen. Je genauer du dein Projekt beschreibst, desto besser kann ich dir ein Angebot machen.
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>

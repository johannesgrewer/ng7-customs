---
import Layout from '../layouts/Layout.astro';
import ShopGrid from '../components/ShopGrid.astro';

const res = await fetch('https://ng7-contact.contact-1f9.workers.dev/api/werke?kategorie=custom');
const data = await res.json() as { name: string; bild_url: string | null }[];
const produkte = data.map(w => ({ name: w.name, bild: w.bild_url ?? '' }));
---

<Layout title="Individualisierung" description="Custom-Arbeiten von NG7 Customs — Gravuren, Finishes, Umbauten.">
  <ShopGrid
    title="Individualisierung"
    breadcrumb="Individualisierung"
    produkte={produkte}
    activeCategory="Individualisierung"
    description="Gravuren, Beschichtungen, Veredelung. Dein Lieblingsstück, einzigartig gemacht."
  />
</Layout>

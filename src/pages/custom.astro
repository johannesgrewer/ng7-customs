---
import Layout from '../layouts/Layout.astro';
import ShopGrid from '../components/ShopGrid.astro';

const produkte = [
  { name: 'Messerkordel I', bild: '/images/produkt-01.webp' },
  { name: 'Messerkordel II', bild: '/images/produkt-02.webp' },
  { name: 'Messerkordel III', bild: '/images/produkt-03.webp' },
  { name: 'Messerkordel IV', bild: '/images/produkt-04.webp' },
  { name: 'Kitchen knife', bild: '/images/produkt-kitchen-knife.webp' },
  { name: 'Laserschwert', bild: '/images/produkt-laserschwert.webp' },
];
---

<Layout title="Individualisierung" description="Custom-Arbeiten von NG7 Customs — Gravuren, Finishes, Umbauten.">
  <ShopGrid
    title="Individualisierung"
    breadcrumb="Individualisierung"
    produkte={produkte}
    activeCategory="Individualisierung"
    description="Gravuren, Beschichtungen, Veredelung. Dein Lieblingsstück, einzigartig gemacht."
  />
</Layout>

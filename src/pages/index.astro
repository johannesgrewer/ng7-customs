---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Kategorien from '../components/Kategorien.astro';
import AboutPreview from '../components/AboutPreview.astro';
import NeueWerke from '../components/NeueWerke.astro';
import WerkstattDivider from '../components/WerkstattDivider.astro';
import WarumNG7 from '../components/WarumNG7.astro';
import Galerie from '../components/Galerie.astro';
import CtaBanner from '../components/CtaBanner.astro';

const produkte = [
  { name: 'Messerkordel I', bild: '/images/produkt-01.webp' },
  { name: 'Messerkordel II', bild: '/images/produkt-02.webp' },
  { name: 'Messerkordel III', bild: '/images/produkt-03.webp' },
  { name: 'Messerkordel IV', bild: '/images/produkt-04.webp' },
];

const galeriebilder = [
  '/images/produkt-05.webp',
  '/images/produkt-06.webp',
  '/images/produkt-07.webp',
];
---

<Layout title="Home">
  <Hero />
  <Kategorien />
  <AboutPreview />
  <NeueWerke produkte={produkte} />
  <WerkstattDivider />
  <WarumNG7 />
  <Galerie bilder={galeriebilder} />
  <CtaBanner />
</Layout>

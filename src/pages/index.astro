---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Kategorien from '../components/Kategorien.astro';
import AboutPreview from '../components/AboutPreview.astro';
import NeueWerke from '../components/NeueWerke.astro';
import WerkstattDivider from '../components/WerkstattDivider.astro';
import WarumNG7 from '../components/WarumNG7.astro';
import Galerie from '../components/Galerie.astro';
import CtaBanner from '../components/CtaBanner.astro';

const res = await fetch('https://ng7-contact.contact-1f9.workers.dev/api/werke?kategorie=neue_werke');
const data = await res.json() as { name: string; bild_key: string | null }[];
const produkte = data.map(w => ({ name: w.name, bild: w.bild_key ? `/images/${w.bild_key}` : '' }));

const galeriebilder = [
  '/images/produkt-05.webp',
  '/images/produkt-06.webp',
  '/images/produkt-07.webp',
];
---

<Layout title="Home">
  <Hero />
  <Kategorien />
  <AboutPreview />
  <NeueWerke produkte={produkte} />
  <WerkstattDivider />
  <WarumNG7 />
  <Galerie bilder={galeriebilder} />
  <CtaBanner />
</Layout>

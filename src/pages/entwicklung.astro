---
import Layout from '../layouts/Layout.astro';
import ShopGrid from '../components/ShopGrid.astro';

const produkte = [
  { name: 'Messerkordel I', bild: '/images/produkt-01.webp' },
  { name: 'Messerkordel II', bild: '/images/produkt-02.webp' },
  { name: 'Messerkordel III', bild: '/images/produkt-03.webp' },
  { name: 'Messerkordel IV', bild: '/images/produkt-04.webp' },
  { name: 'Messerkordel V', bild: '/images/produkt-05.webp' },
  { name: 'Messerkordel', bild: '/images/produkt-messerkordel-orig.webp' },
];
---

<Layout title="Entwicklung" description="Produktentwicklung von NG7 Customs — vom Konzept zum fertigen Produkt.">
  <ShopGrid
    title="Entwicklung"
    breadcrumb="Entwicklung"
    produkte={produkte}
    activeCategory="Entwicklung"
    description="Vom Konzept zum fertigen Produkt. Deine Vision, meine Hände."
  />
</Layout>

---
import '../styles/global.css'
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Font-Vergleich | NG7 Customs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Work+Sans:wght@300;400;500;600&family=Outfit:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;500;600&family=Sora:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body style="background: #F5F4F0; margin: 0; padding: 0;">

  <!-- Header -->
  <div style="background: #35342B; padding: 20px 40px; text-align: center;">
    <p style="color: rgba(255,255,255,0.5); font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; margin: 0;">NG7 Customs — Font-Vergleich</p>
  </div>

  <div style="max-width: 1300px; margin: 0 auto; padding: 40px;">

    <!-- ===================== OPTION A ===================== -->
    <div style="background: #FFFFFF; padding: 60px; margin-bottom: 40px; border: 1px solid #E0E0E0;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; border-bottom: 1px solid #E8E8E8; padding-bottom: 20px;">
        <div>
          <span style="font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: #A1A89A;">Option A</span>
          <h2 style="font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 1.8rem; color: #1A1A1A; margin: 5px 0 0 0;">"Industrial Craft"</h2>
        </div>
        <div style="text-align: right; font-size: 13px; color: #999;">
          <p style="margin: 0;">Headlines: <strong>Space Grotesk</strong></p>
          <p style="margin: 0;">Body: <strong>Work Sans</strong></p>
        </div>
      </div>

      <!-- Hero Simulation -->
      <div style="background: #35342B; padding: 60px; margin-bottom: 30px; text-align: center;">
        <p style="font-family: 'Work Sans', sans-serif; font-size: 12px; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 12px;">Die Geschichte</p>
        <h1 style="font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 3.5rem; color: #FFFFFF; margin: 0; line-height: 1.05;">
          Der Mensch hinter dem<br/><span style="color: #A1A89A;">Handwerk</span>
        </h1>
        <p style="font-family: 'Work Sans', sans-serif; font-weight: 300; font-size: 1.1rem; color: rgba(255,255,255,0.6); margin-top: 20px;">
          Verwirkliche deine Vision, ich liefer das Handwerk.
        </p>
      </div>

      <!-- Content Simulation -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: start;">
        <div>
          <p style="font-family: 'Work Sans', sans-serif; font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: #A1A89A; margin-bottom: 8px;">Trier, Deutschland</p>
          <h2 style="font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 2.2rem; color: #1A1A1A; margin: 0 0 20px 0;">Nicolas Meriaux</h2>
          <p style="font-family: 'Work Sans', sans-serif; font-weight: 400; font-size: 1rem; line-height: 1.8; color: #555;">
            Hi, ich bin Nicolas und komme aus der ältesten Stadt Deutschlands – Trier. Hauptberuflich tätig als Mechatroniker, lebe ich hier meine Leidenschaft zu Kreativität, Design und vielseitigen Materialien aus.
          </p>
        </div>
        <div>
          <h3 style="font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 1.3rem; color: #1A1A1A; margin: 0 0 12px 0;">Meine Werte</h3>
          <p style="font-family: 'Work Sans', sans-serif; font-weight: 400; font-size: 1rem; line-height: 1.8; color: #555; margin-bottom: 15px;">
            <strong style="color: #1A1A1A;">Präzision</strong> — Liebe zum Detail, die absolute Präzision sicherstellt. Kein Kompromiss bei der Verarbeitung.
          </p>
          <p style="font-family: 'Work Sans', sans-serif; font-weight: 400; font-size: 1rem; line-height: 1.8; color: #555;">
            <strong style="color: #1A1A1A;">Materialwissen</strong> — Stahl, Holz, Leder, Carbon — jedes Material hat seinen Charakter.
          </p>
          <div style="margin-top: 25px;">
            <a style="font-family: 'Work Sans', sans-serif; font-weight: 500; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; padding: 12px 30px; background: #656350; color: #FFF; text-decoration: none; display: inline-block;">Projekt anfragen</a>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; padding-top: 30px; border-top: 1px solid #E8E8E8; text-align: center;">
        <div>
          <span style="font-family: 'Space Grotesk', sans-serif; font-weight: 400; font-size: 3rem; color: #A1A89A;">250+</span>
          <p style="font-family: 'Work Sans', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: #999; margin-top: 5px;">Einzelstücke</p>
        </div>
        <div>
          <span style="font-family: 'Space Grotesk', sans-serif; font-weight: 400; font-size: 3rem; color: #A1A89A;">100%</span>
          <p style="font-family: 'Work Sans', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: #999; margin-top: 5px;">Handarbeit</p>
        </div>
        <div>

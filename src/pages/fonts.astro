        </div>
        <div>
          <span style="font-family: 'Space Grotesk', sans-serif; font-weight: 400; font-size: 3rem; color: #A1A89A;">∞</span>
          <p style="font-family: 'Work Sans', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: #999; margin-top: 5px;">Möglichkeiten</p>
        </div>
      </div>
    </div>


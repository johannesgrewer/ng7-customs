---
import Layout from '../layouts/Layout.astro';

const produkte = [
  { name: 'Kordelmesser "Fjord"', preis: '280', material: 'Carbon-Stahl, Paracord', kategorie: 'Messer', verfuegbar: true, bild: '/images/produkt-01.jpg' },
  { name: 'Schlüsselanhänger "Hex"', preis: '45', material: 'Edelstahl, gebürstet', kategorie: 'Accessoires', verfuegbar: true, bild: '/images/produkt-02.jpg' },
  { name: 'Flaschenöffner "Barkeeper"', preis: '65', material: 'Messing, handgeschmiedet', kategorie: 'Accessoires', verfuegbar: true, bild: '/images/produkt-03.jpg' },
  { name: 'Jagdmesser "Eifel"', preis: '420', material: 'Damaszener Stahl, Olivenholz', kategorie: 'Messer', verfuegbar: false, bild: '/images/produkt-04.jpg' },
  { name: 'Lederscheide Universal', preis: '85', material: 'Rindsleder, handgenäht', kategorie: 'Zubehör', verfuegbar: true, bild: '/images/produkt-05.jpg' },
  { name: 'Skulptur "Twist"', preis: '350', material: 'Edelstahl, geschweißt', kategorie: 'Kunst', verfuegbar: true, bild: '/images/produkt-06.jpg' },
  { name: 'Klingenschutz "Snap"', preis: '25', material: 'PETG, 3D-gedruckt', kategorie: 'Zubehör', verfuegbar: true, bild: '/images/produkt-07.jpg' },
  { name: 'EDC Pry Bar', preis: '55', material: 'Titan Grade 5', kategorie: 'Accessoires', verfuegbar: true, bild: '/images/produkt-08.jpg' },
];
---

<Layout title="Shop" description="NG7 Customs Shop — Handgefertigte Messer, Accessoires und Kunstobjekte kaufen. Einzelstücke aus Trier.">

  <!-- Page Header -->
  <section class="pt-32 pb-8 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--ng7-accent)] mb-3">Shop</p>
      <h1 style="font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 7vw, 5rem); letter-spacing: 0.02em;">Verfügbare Werke</h1>
      <p class="mt-4 text-[var(--ng7-text-dim)] max-w-xl leading-relaxed">
        Fertige Stücke, sofort verfügbar. Jedes Produkt ist handgefertigt und ein Unikat.
      </p>
    </div>
  </section>

  <!-- Filter (Mockup) -->
  <section class="pb-6 px-6">
    <div class="max-w-6xl mx-auto flex flex-wrap gap-3">
      <button class="text-xs uppercase tracking-widest px-4 py-2 bg-[var(--ng7-accent)] text-[var(--ng7-black)] font-semibold">Alle</button>
      <button class="text-xs uppercase tracking-widest px-4 py-2 border border-[var(--ng7-border)] text-[var(--ng7-text-dim)] hover:border-[var(--ng7-accent)] hover:text-[var(--ng7-accent)] transition-colors">Messer</button>
      <button class="text-xs uppercase tracking-widest px-4 py-2 border border-[var(--ng7-border)] text-[var(--ng7-text-dim)] hover:border-[var(--ng7-accent)] hover:text-[var(--ng7-accent)] transition-colors">Accessoires</button>
      <button class="text-xs uppercase tracking-widest px-4 py-2 border border-[var(--ng7-border)] text-[var(--ng7-text-dim)] hover:border-[var(--ng7-accent)] hover:text-[var(--ng7-accent)] transition-colors">Zubehör</button>
      <button class="text-xs uppercase tracking-widest px-4 py-2 border border-[var(--ng7-border)] text-[var(--ng7-text-dim)] hover:border-[var(--ng7-accent)] hover:text-[var(--ng7-accent)] transition-colors">Kunst</button>
    </div>
  </section>

  <!-- Product Grid -->
  <section class="pb-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {produkte.map((p) => (
          <div class="group border border-[var(--ng7-border)] bg-[var(--ng7-surface)] hover:border-[var(--ng7-accent)] transition-all duration-300">
            <!-- Image -->
            <div class="aspect-square bg-[var(--ng7-surface-light)] relative overflow-hidden">
              <img src={p.bild} alt={p.name} class="w-full h-full object-cover" />
              {!p.verfuegbar && (
                <div class="absolute inset-0 bg-[var(--ng7-black)]/60 flex items-center justify-center">
                  <span class="text-[10px] uppercase tracking-widest text-[var(--ng7-text-dim)]">Ausverkauft</span>
                </div>
              )}
              <span class="absolute top-3 left-3 text-[10px] uppercase tracking-widest bg-[var(--ng7-black)]/80 text-[var(--ng7-text-dim)] px-2 py-1">{p.kategorie}</span>
            </div>

            <!-- Info -->
            <div class="p-5">
              <h3 class="text-sm font-semibold mb-1">{p.name}</h3>
              <p class="text-xs text-[var(--ng7-text-muted)] mb-3">{p.material}</p>
              <div class="flex justify-between items-center">
                <span class="text-lg font-semibold text-[var(--ng7-accent)]">{p.preis} €</span>
                {p.verfuegbar ? (
                  <a href="/kontakt" class="text-[10px] uppercase tracking-widest text-[var(--ng7-accent)] border border-[var(--ng7-accent)] px-3 py-1.5 hover:bg-[var(--ng7-accent-glow)] transition-colors">Anfragen</a>
                ) : (
                  <span class="text-[10px] uppercase tracking-widest text-[var(--ng7-text-muted)]">Vergriffen</span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="py-16 px-6 border-t border-[var(--ng7-border)] bg-[var(--ng7-surface)]">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
      <div>
        <span class="text-xl text-[var(--ng7-accent)] block mb-2">✦</span>
        <h4 class="text-xs uppercase tracking-widest mb-1">Handgemacht</h4>
        <p class="text-xs text-[var(--ng7-text-dim)]">Jedes Stück ist ein Unikat, gefertigt in Trier.</p>
      </div>
      <div>
        <span class="text-xl text-[var(--ng7-accent)] block mb-2">◆</span>
        <h4 class="text-xs uppercase tracking-widest mb-1">Versand DE</h4>
        <p class="text-xs text-[var(--ng7-text-dim)]">Versicherter Versand innerhalb Deutschlands.</p>
      </div>
      <div>
        <span class="text-xl text-[var(--ng7-accent)] block mb-2">⬡</span>
        <h4 class="text-xs uppercase tracking-widest mb-1">Auf Anfrage</h4>
        <p class="text-xs text-[var(--ng7-text-dim)]">Kein Warenkorb — persönliche Abwicklung per Mail.</p>
      </div>
    </div>
  </section>

</Layout>

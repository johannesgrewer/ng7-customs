<!-- 1. HERO — Video + Claim (dunkel, fullscreen) -->
<section class="relative h-[80vh] flex items-center justify-center overflow-hidden">
  <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover" preload="auto">
    <source src="/video/hero.mp4" type="video/mp4" />
  </video>
  <div class="absolute inset-0" style="background: rgba(0,0,0,0.45);"></div>

  <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
    <h1 style="font-family: var(--font-display); font-weight: 500; font-size: clamp(2.2rem, 6vw, 4rem); line-height: 1.1; color: #FFFFFF; letter-spacing: -0.01em;">
      Maßgefertigtes Handwerk
    </h1>
    <p class="mt-4 text-base text-white/70 max-w-md mx-auto" style="font-family: var(--font-body);">
      Verwirkliche deine Vision, ich liefer das Handwerk.
    </p>
    <div class="mt-8">
      <a href="/#kategorien" class="btn-outline-white">Entdecken</a>
    </div>
  </div>
</section>

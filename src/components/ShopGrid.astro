---
interface Product {
  name: string;
  preis: string;
  bild: string;
}

interface Props {
  title: string;
  breadcrumb?: string;
  produkte: Product[];
  activeCategory: string;
}

const { title, breadcrumb, produkte, activeCategory } = Astro.props;

const categories = [
  { name: 'Alle Produkte', href: '/shop' },
  { name: 'Custom Page', href: '/custom' },
  { name: 'Entwicklung Page', href: '/entwicklung' },
  { name: 'Nach Maß Page', href: '/einzelstuecke' },
  { name: 'Neue Werke 2025', href: '/shop' },
];
---

<!-- Breadcrumb -->
<div class="pt-24 pb-2 px-6" style="background: #FFFFFF;">
  <div class="max-w-[1200px] mx-auto">
    <p class="text-xs" style="color: #999;">
      <a href="/" class="hover:text-[#1A1A1A] transition-colors">Start</a> &gt; {breadcrumb || title}
    </p>
  </div>
</div>

<!-- Page Title -->
<div class="pb-6 px-6" style="background: #FFFFFF;">
  <div class="max-w-[1200px] mx-auto">
    <h1 style="font-family: 'Rubik', sans-serif; font-weight: 500; font-size: 1.6rem; color: #1A1A1A;">{title}</h1>
  </div>
</div>

<!-- Content: Sidebar + Grid -->
<section class="pb-20 px-6" style="background: #FFFFFF;">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-[200px_1fr] gap-10">

    <!-- Sidebar -->
    <aside>
      <div class="flex justify-between items-center mb-3">
        <h3 class="text-sm font-medium" style="color: #1A1A1A; font-family: 'Rubik', sans-serif;">Kategorien</h3>
        <span class="text-xs" style="color: #999;">{produkte.length} Produkte</span>
      </div>
      <nav class="flex flex-col gap-1">
        {categories.map((cat) => (
          <a
            href={cat.href}
            class={`text-[13px] py-1 transition-colors ${cat.name === activeCategory ? 'font-medium' : ''}`}
            style={cat.name === activeCategory ? 'color: #1A1A1A;' : 'color: #999;'}
          >
            {cat.name}
          </a>
        ))}
      </nav>
    </aside>

    <!-- Product Grid -->
    <div>
      <div class="flex justify-end mb-4">
        <span class="text-xs" style="color: #999;">Sortierung: Empfohlen</span>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {produkte.map((p) => (
          <div class="group bg-white">
            <div class="aspect-square overflow-hidden relative" style="background: #F0F0F0;">
              <img src={p.bild} alt={p.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/25 transition-all flex items-center justify-center">
                <span class="opacity-0 group-hover:opacity-100 text-[9px] uppercase tracking-widest text-white border border-white px-2 py-1 transition-opacity">Schnellansicht</span>
              </div>
            </div>
            <div class="pt-2 pb-3">
              <p class="text-[12px] mb-1" style="color: #1A1A1A; font-family: 'DM Sans', sans-serif;">{p.name}</p>
              <span class="text-[12px]" style="color: #6E6E6E;">{p.preis}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
interface Product {
  name: string;
  bild: string;
}

interface Props {
  title: string;
  breadcrumb?: string;
  produkte: Product[];
  activeCategory: string;
  description?: string;
}

const { title, breadcrumb, produkte, activeCategory, description } = Astro.props;
---

<!-- Hero Banner -->
<section class="relative pt-32 pb-20 px-6 overflow-hidden" style="background: #1A1917;">
  <!-- Große Hintergrund-Nummer -->
  <div class="absolute top-1/2 right-10 -translate-y-1/2 pointer-events-none select-none hidden lg:block" aria-hidden="true">
    <span class="text-[20vw] font-bold leading-none" style="color: rgba(160,151,125,0.03); font-family: var(--font-display);">{String(produkte.length).padStart(2, '0')}</span>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto">
    <!-- Breadcrumb -->
    <p class="text-[11px] tracking-[0.2em] uppercase mb-8" style="color: #8A8070; font-family: var(--font-body);">
      <a href="/" class="hover:text-[#A0977D] transition-colors">Start</a>
      <span class="mx-2" style="color: #A0977D33;">/</span>
      {breadcrumb || title}
    </p>

    <p class="text-[11px] uppercase tracking-[0.4em] mb-3" style="color: #A0977D; font-family: var(--font-body);">Kollektion</p>
    <h1 class="mb-4" style="font-family: var(--font-display); font-weight: 500; font-size: clamp(2rem, 5vw, 3rem); color: #F5F0E8;">{title}</h1>

    {description && (
      <p class="text-[15px] max-w-lg mb-6" style="color: #8A8070; font-family: var(--font-body);">{description}</p>
    )}

    <div class="flex items-center gap-5 mt-6">
      <div class="h-px flex-1" style="background: linear-gradient(to right, #A0977D44, transparent);"></div>
      <span class="text-[11px] uppercase tracking-[0.2em]" style="color: #A0977D; font-family: var(--font-body);">{produkte.length} Werke</span>
    </div>
  </div>
</section>

<!-- Product Grid -->
<section class="pb-24 px-6" style="background: #1A1917;">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      {produkte.map((p, i) => (
        <div class="group cursor-default">
          <div class="relative aspect-[3/4] overflow-hidden" style="background: #2A2723;">
            <img src={p.bild} alt={p.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <!-- Hover Overlay -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-all duration-500 flex items-center justify-center">
              <a href="/kontakt" class="opacity-0 group-hover:opacity-100 text-[10px] uppercase tracking-[0.15em] text-white border border-white/60 px-4 py-2 transition-all duration-500 hover:bg-white/10">Anfragen</a>
            </div>
            <!-- Nummer -->
            <span class="absolute top-3 left-3 text-[11px] tracking-[0.3em]" style="color: #A0977D; font-family: var(--font-body);">0{i + 1}</span>
            <!-- Innerer Rahmen -->
            <div class="absolute inset-2 border border-white/0 group-hover:border-white/10 transition-colors duration-500 pointer-events-none"></div>
          </div>
          <!-- Info -->
          <div class="pt-4 pb-2">
            <div class="h-px mb-3" style="background: #A0977D22;"></div>
            <p class="text-[13px] tracking-wide" style="color: #F5F0E8; font-family: var(--font-display);">{p.name}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16 px-6" style="background: #4A4639;">
  <div class="max-w-[1200px] mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
    <div>
      <h2 style="font-family: var(--font-display); font-weight: 500; font-size: 1.6rem; color: #F5F0E8;">Dein Wunschstück nicht dabei?</h2>
      <p class="text-[14px] mt-2" style="color: #B5AFA3; font-family: var(--font-body);">Schreib mir und wir finden gemeinsam eine Lösung.</p>
    </div>
    <a href="/kontakt" class="inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.2em] px-6 py-3 border transition-all hover:bg-white/10 flex-shrink-0" style="color: #F5F0E8; border-color: #A0977D;">
      Jetzt anfragen
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- 2. KATEGORIEN — Expanding Panels -->
<section id="kategorien" style="background: #656350;" class="py-20 px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="flex items-center gap-5 mb-12">
      <h2 style="font-family: var(--font-display); font-weight: 500; font-size: 1.6rem; color: #FFFFFF; white-space: nowrap;">Kategorien</h2>
      <div class="h-px flex-1" style="background: linear-gradient(to right, rgba(255,255,255,0.3), transparent);"></div>
    </div>

    <div class="kat-panels flex flex-col md:flex-row gap-2 md:h-[550px]">
      {[
        { href: '/einzelstuecke', img: '/images/kat-einzelstuecke.webp', alt: 'Einzelstücke', nr: '01', title: 'Einzelstücke', desc: 'Unikate mit Charakter — jedes Stück ein Original aus Handarbeit.' },
        { href: '/entwicklung', img: '/images/kat-nachmass.webp', alt: 'Auf-/Nach Maß', nr: '02', title: 'Auf-/Nach Maß', desc: 'Deine Vision, meine Hände — maßgeschneidert nach deinen Wünschen.' },
        { href: '/custom', img: '/images/kat-custom.webp', alt: 'Finishes', nr: '03', title: 'Finishes', desc: 'Individualisierung deiner Lieblingsstücke — Gravuren, Beschichtungen, Veredelung.' },
      ].map((kat) => (
        <a href={kat.href} class="kat-panel group relative flex-1 overflow-hidden transition-all duration-700 ease-in-out min-h-[200px] md:min-h-0 md:hover:flex-[3]" style="background: #35342B;">
          <img src={kat.img} alt={kat.alt} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" width="600" height="800" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 group-hover:from-black/70 group-hover:via-black/20 group-hover:to-transparent transition-all duration-500"></div>
          <!-- Vertikaler Titel (sichtbar wenn schmal) -->
          <div class="absolute inset-0 hidden md:flex items-center justify-center group-hover:opacity-0 transition-opacity duration-300">
            <h3 class="text-sm uppercase tracking-[0.3em] text-white/80 whitespace-nowrap" style="font-family: var(--font-display); writing-mode: vertical-rl; transform: rotate(180deg);">{kat.title}</h3>
          </div>
          <!-- Mobile Titel (immer sichtbar) -->
          <div class="absolute bottom-0 left-0 right-0 p-5 md:hidden">
            <h3 class="text-lg uppercase tracking-widest text-white" style="font-family: var(--font-display); font-weight: 500;">{kat.title}</h3>
            <p class="text-[13px] text-white/60 mt-1" style="font-family: var(--font-body);">{kat.desc}</p>
          </div>
          <!-- Expanded Content (Desktop) -->
          <div class="absolute bottom-0 left-0 right-0 p-6 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0 hidden md:block">
            <span class="text-[11px] tracking-[0.3em] uppercase mb-1 block" style="color: #A0977D;">{kat.nr}</span>
            <h3 class="text-xl uppercase tracking-widest text-white mb-2" style="font-family: var(--font-display); font-weight: 500;">{kat.title}</h3>
            <p class="text-[13px] leading-relaxed text-white/60 max-w-xs mb-3" style="font-family: var(--font-body);">{kat.desc}</p>
            <span class="flex items-center gap-2 text-[11px] uppercase tracking-[0.15em] text-white/80">
              Entdecken
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

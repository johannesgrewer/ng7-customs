---
let settings: Record<string, string | null> = {};
try {
  const res = await fetch('https://ng7-contact.contact-1f9.workers.dev/api/settings');
  if (res.ok) settings = await res.json();
} catch {}

const kategorien = [
  {
    href: '/einzelstuecke',
    img: settings.kat_einzelstuecke ?? '/images/kat-einzelstuecke.webp',
    alt: 'Einzelstücke',
    nr: '01',
    title: 'Einzelstücke',
    desc: 'Unikate mit Charakter — jedes Stück ein Original aus Handarbeit.',
  },
  {
    href: '/entwicklung',
    img: settings.kat_entwicklung ?? '/images/kat-nachmass.webp',
    alt: 'Entwicklung',
    nr: '02',
    title: 'Entwicklung',
    desc: 'Deine Vision, meine Hände — maßgeschneidert nach deinen Wünschen.',
  },
  {
    href: '/custom',
    img: settings.kat_custom ?? '/images/kat-custom.webp',
    alt: 'Individualisierung',
    nr: '03',
    title: 'Individualisierung',
    desc: 'Individualisierung deiner Lieblingsstücke — Gravuren, Beschichtungen, Veredelung.',
  },
];
---

<style>
  .kat-panel {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .kat-panel.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .kat-panel:nth-child(1) { transition-delay: 0s; }
  .kat-panel:nth-child(2) { transition-delay: 0.12s; }
  .kat-panel:nth-child(3) { transition-delay: 0.24s; }

  @media (hover: hover) {
    .kat-panel:hover img {
      transform: scale(1.06);
      filter: brightness(1) !important;
    }
    .kat-panel:hover .kat-overlay {
      background: linear-gradient(to top, rgba(0,0,0,0.65), rgba(0,0,0,0.15) 50%, transparent) !important;
    }
    .kat-panel:hover .kat-plus {
      transform: scale(1) !important;
      opacity: 1 !important;
    }
  }
</style>

<script>
  function initKatStagger() {
    const panels = document.querySelectorAll('.kat-panel');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    panels.forEach(p => observer.observe(p));
  }
  initKatStagger();
  document.addEventListener('astro:after-swap', initKatStagger);
</script>

<!-- 2. KATEGORIEN — Expanding Panels -->
<section id="kategorien" style="background: #656350;" class="py-20 px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="flex flex-col items-center text-center md:flex-row md:items-center md:text-left gap-5 mb-12">
      <h2 style="font-family: var(--font-display); font-weight: 500; font-size: 1.6rem; color: #FFFFFF; white-space: nowrap;">Kategorien</h2>
      <div class="hidden md:block h-px flex-1" style="background: linear-gradient(to right, rgba(255,255,255,0.3), transparent);"></div>
    </div>

    <div class="kat-panels flex flex-col gap-5 md:flex-row md:gap-2 md:h-[550px]">
      {kategorien.map((kat) => (
        <a href={kat.href} class="kat-panel group flex flex-col md:relative md:flex-1 md:overflow-hidden md:hover:flex-[3]" style="background: #35342B; transition: flex 0.8s cubic-bezier(0.4, 0, 0.2, 1);">

          <!-- Bild-Container -->
          <div class="relative h-[240px] overflow-hidden md:absolute md:inset-0 md:h-auto">
            <img src={kat.img} alt={kat.alt} class="w-full h-full object-cover" style="transition: transform 0.9s cubic-bezier(0.25, 0.1, 0.25, 1), filter 0.9s cubic-bezier(0.25, 0.1, 0.25, 1); filter: brightness(0.85);" loading="lazy" width="600" height="800" />
            <!-- Overlay nur Desktop -->
            <div class="kat-overlay hidden md:block absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.75), rgba(0,0,0,0.25) 50%, rgba(0,0,0,0.08)); transition: background 0.8s cubic-bezier(0.25, 0.1, 0.25, 1);"></div>
          </div>

          <!-- Mobile Textkasten -->
          <div class="md:hidden px-5 py-4" style="background: #2A2723;">
            <span class="text-[10px] tracking-[0.3em] uppercase block mb-1" style="color: #A0977D; font-family: var(--font-body);">{kat.nr}</span>
            <h3 class="text-base uppercase tracking-[0.12em] font-medium" style="font-family: var(--font-display); color: #F5F0E8;">{kat.title}</h3>
            <p class="text-[13px] leading-relaxed mt-1" style="font-family: var(--font-body); color: #8A8070;">{kat.desc}</p>
            <span class="flex items-center gap-2 text-[11px] uppercase tracking-[0.15em] mt-3" style="color: #A0977D; font-family: var(--font-body);">
              Entdecken
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>

          <!-- Desktop: Plus-Icon oben rechts -->
          <div class="kat-plus hidden md:flex absolute top-5 right-5 z-10 w-9 h-9 items-center justify-center rounded-full opacity-0 group-hover:opacity-100" style="background: rgba(160,151,125,0.25); backdrop-filter: blur(6px); border: 1px solid rgba(160,151,125,0.3); transition: opacity 0.5s cubic-bezier(0.25, 0.1, 0.25, 1) 0.15s, transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1) 0.15s, background 0.3s; transform: scale(0.7); pointer-events: none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </div>

          <!-- Desktop: Vertikaler Titel (schmal) -->
          <div class="absolute inset-0 hidden md:flex items-center justify-center group-hover:opacity-0" style="transition: opacity 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);">
            <h3 class="text-sm uppercase tracking-[0.3em] text-white/80 whitespace-nowrap" style="font-family: var(--font-display); writing-mode: vertical-rl; transform: rotate(180deg);">{kat.title}</h3>
          </div>

          <!-- Desktop: Expanded Content -->
          <div class="absolute bottom-0 left-0 right-0 p-6 opacity-0 translate-y-6 group-hover:opacity-100 group-hover:translate-y-0 hidden md:block" style="transition: opacity 0.7s cubic-bezier(0.25, 0.1, 0.25, 1) 0.1s, transform 0.7s cubic-bezier(0.25, 0.1, 0.25, 1) 0.1s;">
            <span class="text-[11px] tracking-[0.3em] uppercase mb-1 block" style="color: #A0977D;">{kat.nr}</span>
            <h3 class="text-xl uppercase tracking-widest text-white mb-2" style="font-family: var(--font-display); font-weight: 500;">{kat.title}</h3>
            <p class="text-[13px] leading-relaxed text-white/60 max-w-xs mb-3" style="font-family: var(--font-body);">{kat.desc}</p>
            <span class="flex items-center gap-2 text-[11px] uppercase tracking-[0.15em] text-white/80">
              Entdecken
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
